{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HousingForecastPrediction",
  "type": "object",
  "required": [
    "city",
    "prediction_type",
    "horizon_months",
    "predicted_value",
    "confidence",
    "model_name",
    "generated_at"
  ],
  "properties": {
    "city": { "type": "string" },
    "prediction_type": {
      "type": "string",
      "enum": ["future_housing_pressure_score", "future_rent_growth", "future_price_growth"]
    },
    "horizon_months": { "type": "integer", "minimum": 1 },
    "predicted_value": { "type": "number" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "model_name": { "type": "string" },
    "generated_at": { "type": "string" },
    "feature_version": { "type": "string" }
  }
}
