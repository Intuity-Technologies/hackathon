{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HousingPrediction",
  "type": "object",
  "required": [
    "city",
    "prediction_type",
    "time_period",
    "predicted_value",
    "confidence",
    "model_name"
  ],
  "properties": {
    "city": { "type": "string" },
    "prediction_type": {
      "type": "string",
      "enum": ["median_price", "rent", "growth_rate"]
    },
    "time_period": { "type": "integer" },
    "predicted_value": { "type": "number" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "model_name": { "type": "string" }
  }
}
